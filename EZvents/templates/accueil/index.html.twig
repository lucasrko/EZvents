{% extends 'base.html.twig' %}

{% block title %}EZvents{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/Accueil.css') }}"
{% endblock %}

{% block body %}
    <div class="homepage-container">

        <header class="header-home">

            <form action="#" method="GET" class="search-form">
                <input type="search" name="q" placeholder="Rechercher un événement, un lieu..." class="search-input">
                <button type="submit" class="btn-search">Rechercher</button>
            </form>

            <div class="header-actions">
                <a href="{{ path('app_create') }}" class="btn btn-create">Créer un événement</a>

                <a href="#" class="profile-link" title="Mon profil">
                    <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" fill="currentColor" class="bi bi-person-circle" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
                    </svg>
                </a>
            </div>

        </header>

        <main class="main-content">
            <h1>Bienvenue sur EZvents ! 👋</h1>
            <p>Trouvez et créez des événements en quelques clics.</p>
        </main>

    </div>
{% endblock %}
