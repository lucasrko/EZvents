{% extends 'base.html.twig' %}

{% block title %}EZvents{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/Accueil.css') }}"
{% endblock %}

{% block body %}
    <div class="homepage-container">

        <header class="header-home">

            <form action="{{ path('app_search') }}" method="GET" class="search-form-advanced">
                <div class="search-main-row">
                    <input type="search" name="q" value="{{ app.request.query.get('q') }}" placeholder="Rechercher par nom d'événement..." class="search-input" aria-label="Nom de l'événement">
                    <button type="submit" class="btn-search">Rechercher 🔍</button>
                </div>

                <div class="search-filters-row" style="display: flex; gap: 10px; margin-top: 10px; flex-wrap: wrap;">

                    <input type="text" name="ville" value="{{ app.request.query.get('ville') }}" placeholder="Ville" class="search-input-sub js-city-input" style="flex: 1; min-width: 120px;">

                    <input type="text" name="cp" value="{{ app.request.query.get('cp') }}" placeholder="Code Postal" class="search-input-sub js-zipcode-input" style="flex: 1; min-width: 100px;">

                    <input type="text" name="equipe" value="{{ app.request.query.get('equipe') }}" placeholder="Nom d'équipe (VS)" class="search-input-sub" style="flex: 1; min-width: 150px;">

                    <select name="jeu" class="search-select" style="flex: 1; min-width: 150px; background: #1e293b; color: #fff; border: 1px solid #334155; border-radius: 6px; padding: 0.5rem;">
                        <option value="">Tous les jeux 🎮</option>
                        <option value="cs2" {{ app.request.query.get('jeu') == 'cs2' ? 'selected' : '' }}>Counter-Strike 2</option>
                        <option value="lol" {{ app.request.query.get('jeu') == 'lol' ? 'selected' : '' }}>League of Legends</option>
                        <option value="valorant" {{ app.request.query.get('jeu') == 'valorant' ? 'selected' : '' }}>Valorant</option>
                        <option value="rl" {{ app.request.query.get('jeu') == 'rl' ? 'selected' : '' }}>Rocket League</option>
                        <option value="fortnite" {{ app.request.query.get('jeu') == 'fortnite' ? 'selected' : '' }}>Fortnite</option>
                        <option value="bs" {{ app.request.query.get('jeu') == 'bs' ? 'selected' : '' }}>Brawl Stars</option>
                        <option value="cod" {{ app.request.query.get('jeu') == 'cod' ? 'selected' : '' }}>Call Of Duty</option>
                        <option value="dota 2" {{ app.request.query.get('jeu') == 'dota 2' ? 'selected' : '' }}>Dota 2</option>
                        <option value="overwatch" {{ app.request.query.get('jeu') == 'overwatch' ? 'selected' : '' }}>Overwatch</option>
                        <option value="Street Fighter" {{ app.request.query.get('jeu') == 'Street Fighter' ? 'selected' : '' }}>Street Fighter</option>
                        <option value="tekken" {{ app.request.query.get('jeu') == 'tekken' ? 'selected' : '' }}>Tekken</option>
                        <option value="tft" {{ app.request.query.get('jeu') == 'tft' ? 'selected' : '' }}>Team Fight Tactics</option>
                        <option value="apex" {{ app.request.query.get('jeu') == 'apex' ? 'selected' : '' }}>Apex Legends</option>
                        <option value="R6" {{ app.request.query.get('jeu') == 'R6' ? 'selected' : '' }}>Rainbow Six Siege</option>
                    </select>

                    <input type="date" name="date" value="{{ app.request.query.get('date') }}" class="search-date" style="background: #1e293b; color: #fff; border: 1px solid #334155; border-radius: 6px; padding: 0.5rem;">
                </div>
            </form>

            <div class="header-actions">
                <a href="{{ path('app_create') }}" class="btn btn-create">Créer un événement</a>

                {% if app.user %}
                    <a href="{{ path('app_profil', {'pseudo': app.user.pseudo}) }}" class="profile-link" title="Mon profil">
                        <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" fill="currentColor" class="bi bi-person-circle" viewBox="0 0 16 16">
                            <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                            <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
                        </svg>
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn-login" style="color: #fff; text-decoration: none; border: 1px solid #334155; padding: 0.5rem 1rem; border-radius: 6px;">Connexion</a>
                {% endif %}
            </div>

        </header>

        <main class="main-content">
            <h1>Bienvenue sur EZvents ! 👋</h1>
            <p>Trouvez et créez des événements en quelques clics.</p>

            <section class="events-section">
                <h2>Événements à la une 🎮</h2>

                <div class="events-grid">
                    {% for event in events %}
                        <div class="event-card">
                            <span class="badge-game game-{{ event.categorie }}">{{ event.categorie|upper }}</span>

                            <div class="event-card-body">
                                <h3>{{ event.name }}</h3>
                                <p class="event-date">📅 {{ event.dateHeure|date('d/m/Y à H:i') }}</p>
                                <p class="event-desc">{{ event.description|slice(0, 100) }}...</p>

                                <div class="event-teams">
                                    {% if event.nomEquipe1 and event.nomEquipe2 %}
                                        <span class="team">{{ event.nomEquipe1 }}</span>
                                        <span class="vs">VS</span>
                                        <span class="team">{{ event.nomEquipe2 }}</span>
                                    {% else %}
                                        <span class="location">📍 {{ event.adresse }}</span>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="event-card-footer">
                                <span class="capacity">👥 {{ event.capacite }} places</span>
                                <a href="{{ path('app_event', {'id': event.id}) }}" class="btn-details">Voir l'event</a>
                            </div>
                        </div>
                    {% else %}
                        <p class="no-events">Aucun événement n'est disponible pour le moment. Soyez le premier à en créer un !</p>
                    {% endfor %}
                </div>
            </section>
        </main>

    </div>
{% endblock %}
