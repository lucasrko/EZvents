{% extends 'base.html.twig' %}

{% block title %}Accueil - EZvents{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/Accueil.css') }}">
{% endblock %}

{% block body %}
    <div class="homepage-container" id="main-content">

        <header class="header-home">

            {# 🔍 Formulaire de recherche accessible #}
            <form action="{{ path('app_search') }}" method="GET" class="search-form-advanced" role="search" aria-label="Recherche avancée d'événements">

                <div class="search-main-row">
                    <input type="search" name="q" value="{{ app.request.query.get('q') }}" placeholder="Rechercher par nom..." class="search-input" aria-label="Rechercher par nom d'événement">
                    <button type="submit" class="btn-search" aria-label="Lancer la recherche">Rechercher</button>
                </div>

                <div class="search-filters-row">
                    <input type="text" name="ville" value="{{ app.request.query.get('ville') }}" placeholder="Ville" class="search-input-sub js-city-input" aria-label="Filtrer par ville">
                    <input type="text" name="cp" value="{{ app.request.query.get('cp') }}" placeholder="Code Postal" class="search-input-sub js-zipcode-input" aria-label="Filtrer par code postal">
                    <input type="text" name="equipe" value="{{ app.request.query.get('equipe') }}" placeholder="Nom d'équipe (VS)" class="search-input-sub" aria-label="Filtrer par nom d'équipe">

                    <select name="jeu" class="search-select" aria-label="Filtrer par jeu vidéo">
                        <option value="">Tous les jeux 🎮</option>
                        <option value="cs2" {{ app.request.query.get('jeu') == 'cs2' ? 'selected' : '' }}>Counter-Strike 2</option>
                        <option value="lol" {{ app.request.query.get('jeu') == 'lol' ? 'selected' : '' }}>League of Legends</option>
                        <option value="valorant" {{ app.request.query.get('jeu') == 'valorant' ? 'selected' : '' }}>Valorant</option>
                        <option value="rl" {{ app.request.query.get('jeu') == 'rl' ? 'selected' : '' }}>Rocket League</option>
                        <option value="fortnite" {{ app.request.query.get('jeu') == 'fortnite' ? 'selected' : '' }}>Fortnite</option>
                        <option value="bs" {{ app.request.query.get('jeu') == 'bs' ? 'selected' : '' }}>Brawl Stars</option>
                        <option value="cod" {{ app.request.query.get('jeu') == 'cod' ? 'selected' : '' }}>Call Of Duty</option>
                        <option value="dota 2" {{ app.request.query.get('jeu') == 'dota 2' ? 'selected' : '' }}>Dota 2</option>
                        <option value="overwatch" {{ app.request.query.get('jeu') == 'overwatch' ? 'selected' : '' }}>Overwatch</option>
                        <option value="Street Fighter" {{ app.request.query.get('jeu') == 'Street Fighter' ? 'selected' : '' }}>Street Fighter</option>
                        <option value="tekken" {{ app.request.query.get('jeu') == 'tekken' ? 'selected' : '' }}>Tekken</option>
                        <option value="tft" {{ app.request.query.get('jeu') == 'tft' ? 'selected' : '' }}>Team Fight Tactics</option>
                        <option value="apex" {{ app.request.query.get('jeu') == 'apex' ? 'selected' : '' }}>Apex Legends</option>
                        <option value="R6" {{ app.request.query.get('jeu') == 'R6' ? 'selected' : '' }}>Rainbow Six Siege</option>
                    </select>

                    <input type="date" name="date" value="{{ app.request.query.get('date') }}" class="search-date" aria-label="Filtrer par date à partir de">
                </div>
            </form>

            <div class="header-actions">
                <a href="{{ path('app_create') }}" class="btn-create" aria-label="Créer un évènement">Créer un évènement</a>

                {% if app.user %}
                    <a href="{{ path('app_profil', {'pseudo': app.user.pseudo}) }}" class="profile-link" aria-label="Accéder à mon profil">
                        <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" fill="currentColor" aria-hidden="true" viewBox="0 0 16 16">
                            <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                            <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
                        </svg>
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn-login" aria-label="Se connecter">Connexion</a>
                {% endif %}
            </div>

        </header>

        <main class="main-content">
            <h1>Bienvenue sur EZvents ! 👋</h1>
            <p class="subtitle">Trouvez et créez des événements en quelques clics.</p>

            <section class="events-section" aria-labelledby="events-title">
                <h2 id="events-title">Événements à la une 🎮</h2>

                <div class="events-grid">
                    {% for event in events %}
                        <article class="event-card bg-{{ event.categorie|lower|replace({' ': ''}) }}">

                            {# 1. Le petit badge du jeu en haut #}
                            {# <span class="badge-game">{{ event.categorie|upper }}</span>#}

                            {# 2. Le corps avec le titre, la date et les équipes #}
                            <div class="event-card-body">
                                <h3>{{ event.name }}</h3>
                                <p class="event-date">📅 {{ event.dateHeure|date('d/m/Y à H:i') }}</p>

                                <div class="event-teams">
                                    {% if event.nomEquipe1 and event.nomEquipe2 %}
                                        <span class="team">{{ event.nomEquipe1 }}</span>
                                        <span class="vs">VS</span>
                                        <span class="team">{{ event.nomEquipe2 }}</span>
                                    {% else %}
                                        <span class="location">📍 {{ event.adresse }}</span>
                                    {% endif %}
                                </div>
                            </div>

                            {# 3. Le bas de la carte avec les places et le bouton #}
                            <div class="event-card-footer">
                                <span class="capacity">👥 {{ event.capacite }} places restantes</span>
                                <a href="{{ path('app_event', {'id': event.id}) }}" class="btn-details">Voir l'event</a>
                            </div>

                        </article>
                    {% else %}
                        <output class="no-events">Aucun événement n'est disponible pour le moment. Soyez le premier à en créer un !</output>
                    {% endfor %}
                </div>
            </section>
        </main>

    </div>
{% endblock %}
