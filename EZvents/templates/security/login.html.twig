{% extends 'base.html.twig' %}

{% block title %}Connexion - EZvents{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
{% endblock %}

{% block body %}
    <main class="auth-container" id="main-content">
        <section class="auth-card" aria-labelledby="login-title">

            <h1 id="login-title" class="auth-title">Connexion</h1>
            <p class="auth-subtitle">Content de vous revoir sur EZvents !</p>

            {# Formulaire accessible (Désactivation de la validation native du navigateur) #}
            <form method="post" novalidate="novalidate" class="accessible-form">

                {# ❌ Message d'erreur géré pour les lecteurs vocaux #}
                {% if error %}
                    <div class="alert alert-danger" role="alert" aria-live="assertive">
                        <span class="sr-only">Erreur :</span> {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {# ℹ️ Message informatif si l'utilisateur est déjà connecté #}
                {% if app.user %}
                    <output class="alert alert-info">
                        Vous êtes connecté en tant que {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Me déconnecter</a>
                    </output>
                {% endif %}

                <div class="form-group">
                    <label for="username" class="form-label">Adresse Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-input" autocomplete="email" aria-required="true" autofocus>
                </div>

                <div class="form-group">
                    <label for="password" class="form-label">Mot de passe</label>
                    <input type="password" name="_password" id="password" class="form-input" autocomplete="current-password" aria-required="true">
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# Optionnel : Décommente si tu utilises le Remember Me #}
                {#
                <div class="form-checkbox-group">
                    <input type="checkbox" name="_remember_me" id="_remember_me" class="form-checkbox">
                    <label for="_remember_me" class="form-checkbox-label">Se souvenir de moi</label>
                </div>
                #}

                <button class="btn-submit" type="submit" aria-label="Se connecter à mon compte">
                    Se connecter
                </button>

            </form>

            <div class="auth-footer">
                <p>Pas encore de compte ? <a href="{{ path('app_register') }}" aria-label="S'inscrire ici">S'inscrire ici</a></p>
            </div>

        </section>
    </main>
{% endblock %}
