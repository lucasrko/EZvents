{% extends 'base.html.twig' %}

{% block title %}Résultats pour "{{ query }}" - EZvents{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/Accueil.css') }}">
{% endblock %}

{% block body %}
    <div class="homepage-container" style="margin-top: 2rem;">
        <a href="{{ path('app_accueil') }}" style="color: #6366f1; text-decoration: none; font-weight: 600;">← Retour à l'accueil</a>

        <main class="main-content" style="margin-top: 1.5rem;">
            <h1>Résultats de recherche 🔍</h1>
            <p style="color: #94a3b8;">{{ events|length }} résultat(s) trouvé(s) pour votre recherche : "<strong>{{ query }}</strong>"</p>

            <section class="events-section" style="margin-top: 2rem;">
                <div class="events-grid">
                    {% for event in events %}
                        <div class="event-card bg-{{ event.categorie|lower|replace({' ': ''}) }}">
                            <div class="event-card-body">
                                <h3>{{ event.name }}</h3>
                                <p class="event-date">📅 {{ event.dateHeure|date('d/m/Y à H:i') }}</p>

                                <div class="event-teams">
                                    {% if event.nomEquipe1 and event.nomEquipe2 %}
                                        <span class="team">{{ event.nomEquipe1 }}</span>
                                        <span class="vs">VS</span>
                                        <span class="team">{{ event.nomEquipe2 }}</span>
                                    {% else %}
                                        <span class="location">📍 {{ event.adresse }}</span>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="event-card-footer">
                                <span class="capacity">👥 {{ event.capacite }} places</span>
                                <a href="{{ path('app_event', {'id': event.id}) }}" class="btn-details">Voir l'event</a>
                            </div>
                        </div>
                    {% else %}
                        <p style="color: #94a3b8; grid-column: 1 / -1; text-align: center; margin-top: 2rem;">
                            Désolé, aucun événement ne correspond à votre recherche. Essayez avec un autre mot-clé !
                        </p>
                    {% endfor %}
                </div>
            </section>
        </main>
    </div>
{% endblock %}
