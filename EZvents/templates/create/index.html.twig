{% extends 'base.html.twig' %}

{% block title %}{{ (isEdit is defined and isEdit) ? "Modifier l'événement" : "Créer un événement" }} - EZvents{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/create.css') }}">
{% endblock %}

{% block body %}
    <main class="auth-container" id="main-content">
        <section class="form-container" aria-labelledby="form-title">

            <h1 id="form-title">{{ (isEdit is defined and isEdit) ? "Modifier l'événement" : "Créer un événement" }}</h1>

            {# Gestion globale des erreurs du formulaire #}
            {% if not eventForm.vars.valid %}
                <div class="alert-danger" role="alert" aria-live="assertive">
                    ⚠️ Le formulaire contient des erreurs. Veuillez vérifier les champs saisis.
                </div>
            {% endif %}

            {{ form_start(eventForm, {'method':'POST', 'attr': {'novalidate': 'novalidate', 'class': 'accessible-form'}}) }}

            {# Nom de l'événement #}
            <div class="form-group">
                {{ form_label(eventForm.name, 'Nom de l\'événement', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(eventForm.name, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Tournoi Major Paris', 'aria-required': 'true'}}) }}
                {{ form_errors(eventForm.name) }}
            </div>

            {# Catégorie (Jeu) #}
            <div class="form-group">
                {{ form_label(eventForm.categorie, 'Jeu', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(eventForm.categorie, {'attr': {'class': 'form-select', 'aria-required': 'true'}}) }}
                {{ form_errors(eventForm.categorie) }}
            </div>

            {# Description #}
            <div class="form-group">
                {{ form_label(eventForm.description, 'Description de l\'événement', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(eventForm.description, {'attr': {'class': 'form-textarea', 'placeholder': 'Détaillez le planning, les récompenses...', 'aria-required': 'true'}}) }}
                {{ form_errors(eventForm.description) }}
            </div>

            {# Équipes #}
            <div class="form-grid-2col">
                <div class="form-group">
                    {{ form_label(eventForm.nom_equipe_1, 'Équipe 1', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(eventForm.nom_equipe_1, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Karmine Corp'}}) }}
                    {{ form_errors(eventForm.nom_equipe_1) }}
                </div>

                <div class="form-group">
                    {{ form_label(eventForm.nom_equipe_2, 'Équipe 2', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(eventForm.nom_equipe_2, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Team Vitality'}}) }}
                    {{ form_errors(eventForm.nom_equipe_2) }}
                </div>
            </div>

            {# Adresse #}
            <div class="form-group">
                {{ form_label(eventForm.adresse, 'Adresse', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(eventForm.adresse, {'attr': {'class': 'form-input js-address-input', 'placeholder': 'Rechercher une adresse...', 'aria-required': 'true'}}) }}
                {{ form_errors(eventForm.adresse) }}
            </div>

            {# Ville & Code Postal #}
            <div class="form-grid-2col">
                <div class="form-group">
                    {{ form_label(eventForm.ville, 'Ville', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(eventForm.ville, {'attr': {'class': 'form-input js-city-input', 'placeholder': 'Ex: Paris', 'aria-required': 'true'}}) }}
                    {{ form_errors(eventForm.ville) }}
                </div>

                <div class="form-group">
                    {{ form_label(eventForm.code_postal, 'Code Postal', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(eventForm.code_postal, {'attr': {'class': 'form-input js-zipcode-input', 'placeholder': 'Ex: 75001', 'aria-required': 'true'}}) }}
                    {{ form_errors(eventForm.code_postal) }}
                </div>
            </div>

            {# Date/Heure & Capacité #}
            <div class="form-grid-2col">
                <div class="form-group">
                    {{ form_label(eventForm.date_heure, 'Date et Heure', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(eventForm.date_heure, {'attr': {'class': 'form-input', 'aria-required': 'true'}}) }}
                    {{ form_errors(eventForm.date_heure) }}
                </div>

                <div class="form-group">
                    {{ form_label(eventForm.capacite, 'Nombre de places maximum', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(eventForm.capacite, {'attr': {'class': 'form-input', 'aria-required': 'true'}}) }}
                    {{ form_errors(eventForm.capacite) }}
                </div>
            </div>

            {# Téléphone #}
            <div class="form-group">
                {{ form_label(eventForm.telephone, 'Numéro de téléphone', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(eventForm.telephone, {'attr': {'class': 'form-input', 'placeholder': '0612345678', 'aria-required': 'true'}}) }}
                {{ form_errors(eventForm.telephone) }}
            </div>

            <button type="submit" class="btn-primary">
                {{ (isEdit is defined and isEdit) ? "Enregistrer les modifications" : "Publier l'événement" }}
            </button>

            {{ form_end(eventForm) }}
        </section>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // 🚀 Fonction globale qui initialise tes écoutes d'API Gouv
        function initAutocomplete() {
            const addressInput = document.querySelector('.js-address-input');
            const cityInput = document.querySelector('.js-city-input');
            const zipInput = document.querySelector('.js-zipcode-input');

            // 🛡️ Sécurité : Évite les doublons d'écouteurs si Turbo recharge le script
            if (addressInput && addressInput.dataset.autocompleteInitialized) return;
            if (addressInput) addressInput.dataset.autocompleteInitialized = "true";

            // ==========================================
            // 1. LOGIQUE POUR LE CHAMP ADRESSE
            // ==========================================
            if (addressInput) {
                addressInput.parentNode.style.position = 'relative';
                const addressContainer = document.createElement('div');
                addressContainer.classList.add('autocomplete-suggestions');
                addressContainer.setAttribute('role', 'listbox');
                addressContainer.style.display = 'none';
                addressInput.parentNode.appendChild(addressContainer);

                addressInput.addEventListener('input', function() {
                    const value = this.value.trim();
                    if (value.length < 5) {
                        addressContainer.style.display = 'none';
                        return;
                    }

                    fetch(`https://api-adresse.data.gouv.fr/search/?q=${encodeURIComponent(value)}&limit=5`)
                        .then(response => response.json())
                        .then(data => {
                            addressContainer.innerHTML = '';
                            if (!data.features || data.features.length === 0) {
                                addressContainer.style.display = 'none';
                                return;
                            }

                            data.features.forEach(feature => {
                                const div = document.createElement('div');
                                div.classList.add('suggestion-item');
                                div.setAttribute('role', 'option');
                                const labelAdresse = feature.properties.name;
                                const city = feature.properties.city;
                                const zipCode = feature.properties.postcode;

                                div.innerHTML = `<span>📍 ${feature.properties.label}</span>`;
                                div.addEventListener('click', function() {
                                    addressInput.value = labelAdresse;
                                    if (cityInput) cityInput.value = city;
                                    if (zipInput) zipInput.value = zipCode;
                                    addressContainer.style.display = 'none';
                                });
                                addressContainer.appendChild(div);
                            });

                            addressContainer.style.top = (addressInput.offsetTop + addressInput.offsetHeight) + 'px';
                            addressContainer.style.left = addressInput.offsetLeft + 'px';
                            addressContainer.style.width = addressInput.offsetWidth + 'px';
                            addressContainer.style.display = 'block';
                        });
                });

                document.addEventListener('click', function(e) {
                    if (e.target !== addressInput) addressContainer.style.display = 'none';
                });
            }

            // ==========================================
            // 2. LOGIQUE POUR LE CHAMP VILLE
            // ==========================================
            if (cityInput) {
                cityInput.parentNode.style.position = 'relative';
                const cityContainer = document.createElement('div');
                cityContainer.classList.add('autocomplete-suggestions');
                cityContainer.setAttribute('role', 'listbox');
                cityContainer.style.display = 'none';
                cityInput.parentNode.appendChild(cityContainer);

                cityInput.addEventListener('input', function() {
                    const value = this.value.trim();
                    if (value.length < 3) {
                        cityContainer.style.display = 'none';
                        return;
                    }

                    fetch(`https://geo.api.gouv.fr/communes?nom=${value}&fields=nom,code,codesPostaux&limit=5`)
                        .then(response => response.json())
                        .then(data => {
                            cityContainer.innerHTML = '';
                            if (data.length === 0) {
                                cityContainer.style.display = 'none';
                                return;
                            }

                            data.forEach(commune => {
                                const div = document.createElement('div');
                                div.classList.add('suggestion-item');
                                div.setAttribute('role', 'option');
                                const zipCode = commune.codesPostaux ? commune.codesPostaux[0] : '';

                                div.innerHTML = `<span>📍 ${commune.nom}</span> <span class="suggestion-zip">${zipCode}</span>`;
                                div.addEventListener('click', function() {
                                    cityInput.value = commune.nom;
                                    if (zipInput && zipCode) zipInput.value = zipCode;
                                    cityContainer.style.display = 'none';
                                });
                                cityContainer.appendChild(div);
                            });

                            cityContainer.style.top = (cityInput.offsetTop + cityInput.offsetHeight) + 'px';
                            cityContainer.style.left = cityInput.offsetLeft + 'px';
                            cityContainer.style.width = cityInput.offsetWidth + 'px';
                            cityContainer.style.display = 'block';
                        });
                });

                document.addEventListener('click', function(e) {
                    if (e.target !== cityInput) cityContainer.style.display = 'none';
                });
            }
        }

        // ==========================================
        // 🚀 GESTION DES ÉCOUTEURS EXTÉRIEURS (TURBO FIX)
        // ==========================================

        // 1. Gère le chargement direct ou le rafraîchissement manuel ($F5$)
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initAutocomplete);
        } else {
            initAutocomplete();
        }

        // 2. Gère la navigation fluide AJAX de Symfony Turbo Drive
        document.addEventListener('turbo:load', initAutocomplete);
    </script>
{% endblock %}
