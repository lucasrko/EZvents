{% extends 'base.html.twig' %}

{% block title %}{{ event.name }} - EZvents{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/Accueil.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/Event.css') }}">
{% endblock %}

{% block body %}
    <main class="details-main-container" id="main-content">

        {# Fiche principale de l'événement #}
        <article class="details-container" aria-labelledby="event-title">

            <a href="{{ path('app_accueil') }}" class="btn-back" aria-label="Retourner à la page d'accueil">← Retour à l'accueil</a>

            <div class="event-header-badge">
                <span class="badge-game game-{{ event.categorie|lower|replace({' ': ''}) }}">{{ event.categorie|upper }}</span>
            </div>

            <h1 id="event-title">{{ event.name }}</h1>

            {# Grille d'informations avec étiquettes de métadonnées #}
            <div class="meta-info">
                <div class="meta-item">
                    <span class="meta-label">📅 Date et Heure</span>
                    <span class="meta-value">{{ event.dateHeure|date('d/m/Y à H:i') }}</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">📍 Adresse</span>
                    <span class="meta-value">{{ event.adresse }}, {{ event.codePostal }} {{ event.ville }}</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">📞 Contact Organisateur</span>
                    <a href="tel:{{ event.telephone }}" class="contact-link meta-value">{{ event.telephone }}</a>
                </div>
                {% if event.organisateur %}
                    <div class="meta-item">
                        <span class="meta-label">👑 Organisé par</span>
                        <a href="{{ path('app_profil', {'pseudo': event.organisateur.pseudo}) }}" class="organizer-link meta-value">
                            {{ event.organisateur.pseudo }}
                        </a>
                    </div>
                {% endif %}
            </div>

            {# Affichage de l'affiche du match (VS) #}
            {% if event.nomEquipe1 and event.nomEquipe2 %}
                <div class="event-match-banner" role="region" aria-label="Affiche du match">
                    <div class="team-block">
                        <span class="meta-label-sm">Équipe 1</span>
                        <span class="team-name">{{ event.nomEquipe1 }}</span>
                    </div>
                    <span class="vs-badge" aria-label="contre">VS</span>
                    <div class="team-block">
                        <span class="meta-label-sm">Équipe 2</span>
                        <span class="team-name">{{ event.nomEquipe2 }}</span>
                    </div>
                </div>
            {% endif %}

            {# Section description #}
            <section class="event-description-section" aria-labelledby="desc-title">
                <h2 id="desc-title">Description de l'événement</h2>
                <p class="event-full-desc">
                    {{ event.description ? event.description : "Aucune description fournie pour cet événement." }}
                </p>
            </section>
        </article>

        {# Module d'inscription #}
        <section class="registration-section" aria-labelledby="registration-title">
            <h2 id="registration-title">Inscription 🎟️</h2>

            <div class="registration-status" aria-live="polite">
                {% if event.getPlacesRestantes <= 0 %}
                    <p class="status-full">⚠️ Événement Complet ! ({{ event.participants.count }}/{{ event.capacite }} places)</p>
                {% else %}
                    <p class="status-available">
                        <span class="meta-label">Disponibilité :</span>
                        <strong>{{ event.getPlacesRestantes }}</strong> places restantes / {{ event.capacite }}
                    </p>
                {% endif %}
            </div>

            <div class="registration-action">
                {% if not app.user %}
                    <a href="{{ path('app_login') }}" class="btn-auth-redirect">Connectez-vous pour vous inscrire</a>
                {% else %}
                    <form action="{{ path('app_event_inscription', {'id': event.id}) }}" method="POST">
                        {% if event.participants.contains(app.user) %}
                            <button type="submit" class="btn-submit-action btn-danger-action">
                                Se désinscrire ❌
                            </button>
                        {% else %}
                            {% if event.getPlacesRestantes <= 0 %}
                                <button type="button" class="btn-submit-action btn-disabled-action" disabled>
                                    Complet 🚫
                                </button>
                            {% else %}
                                <button type="submit" class="btn-submit-action btn-success-action">
                                    S'inscrire 🎉
                                </button>
                            {% endif %}
                        {% endif %}
                    </form>
                {% endif %}
            </div>
        </section>

    </main>
{% endblock %}
